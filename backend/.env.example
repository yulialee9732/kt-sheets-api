# 서버 포트 (Render에서 자동 설정됨)
PORT=3000

# 이메일 설정 - zzoomcctv@gmail.com에서 발송
# Gmail 앱 비밀번호 필요: https://myaccount.google.com/apppasswords
EMAIL_USER=zzoomcctv@gmail.com
